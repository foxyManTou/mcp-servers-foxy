#!/bin/sh
set -e

cd "$(git rev-parse --show-toplevel)"

needs_validate=0
needs_links=0

for file in $(git diff --cached --name-only); do
  case "$file" in
    data/*)
      needs_validate=1
      case "$file" in
        data/servers.json) needs_links=1 ;;
      esac
      ;;
    *.md) needs_links=1 ;;
  esac
done

if [ "$needs_validate" = 1 ]; then
  node scripts/validate-data.mjs
fi

if [ "$needs_links" = 1 ]; then
  node scripts/check-links.mjs
fi
